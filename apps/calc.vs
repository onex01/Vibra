# Vibra Calculator
# Простой калькулятор

print "=== Vibra Calculator ==="
print "Enter expression (example: 2 + 3):"
print ""

# Простой пример вычислений
var a = 10
var b = 5

print "a = " + a
print "b = " + b
print ""
print "a + b = " + (a + b)
print "a - b = " + (a - b)
print "a * b = " + (a * b)
print "a / b = " + (a / b)
print "a % b = " + (a % b)
print ""
print "a > b = " + (a > b)
print "a < b = " + (a < b)
print "a == b = " + (a == b)
